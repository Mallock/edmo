{
  "name": "ed-mission-operator",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Elite Dangerous Mission Operator — always-on-top HUD with journal ingestion, proactive heartbeat, LM Studio AI operator, and local Piper TTS.",
  "engines": {
    "node": ">=22.6.0"
  },
  "scripts": {
    "test": "node --test tests/*.test.ts",
    "replay": "node scripts/replay.ts",
    "replay:ai": "node scripts/replay.ts --ai",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "fetch:tts": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/fetch-tts.ps1",
    "make:icon": "node scripts/make-icon.mjs"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "vite": "^6"
  },
  "license": "MIT"
}
