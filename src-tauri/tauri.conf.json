{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ED Mission Operator",
  "version": "0.3.0",
  "identifier": "ai.laiton.edmissionoperator",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ED Mission Operator",
        "width": 420,
        "height": 680,
        "minWidth": 320,
        "minHeight": 480,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": ["resources/tts"],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
